# Top-level monorepo ignore patterns.
# Sub-projects (Mastra first test/, hindsight docker/, agno for todo/) each
# ship their own .gitignore; keep those in sync if you change tooling.

# Environment files & secrets - DO NOT COMMIT
.env
.env.*
!.env.example
*.env
*.env.local
*.env.development
*.env.production
*.env.test
*.key
*.pem
secrets.json
credentials.json

# Node / TypeScript
node_modules/
.pnpm-store/
dist/
build/
out/
*.tsbuildinfo
.turbo/
.parcel-cache/
.cache/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.python-version
.mypy_cache/
.ruff_cache/
.pyright_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.egg-info/
*.egg
pip-wheel-metadata/
.installed.cfg

# Docker
docker-compose.override.yml
*.override.env

# Logs
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
docker-compose.log

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*.iml

# OS files
.DS_Store
Thumbs.db

# Streamlit
.streamlit/secrets.toml

# Jupyter
.ipynb_checkpoints/

# Supabase local state (the per-project Supabase folder is also covered
# inside agno for todo/.gitignore, but keep an entry here as a safety net)
supabase/.branches/
supabase/.temp/
supabase/.env

# Misc
*.tgz
*.tar.gz
*.bak
